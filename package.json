{
  "name": "hermione-research-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram service for deep professional web research tasks.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "validate:deploy-target": "tsx scripts/validate-deploy-target.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "grammy": "^1.33.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
